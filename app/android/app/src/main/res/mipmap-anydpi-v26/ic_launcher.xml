<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon for tagnet (API 26+). Solid brand-blue background with
  the white tag glyph foreground; the launcher masks it to the device's icon
  shape (circle / squircle / etc.). minSdk is 26, so every device uses this.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
