<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- tagnet: peer sync (outbound / optional listener). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- tagnet: keep the tokio runtime + inotify alive under Doze. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required on API 34+ (Android 14) for a data-sync foreground service. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Needed to post the ongoing notification on API 33+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="tagnet"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <!-- launchMode="singleTask" is recommended by receive_sharing_intent:
             it reuses the existing activity/task for share intents instead of
             spawning a new instance each time a file is shared. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- tagnet: appear in the Android share sheet as an upload target.
                 A single shared item (ACTION_SEND) or several at once
                 (ACTION_SEND_MULTIPLE); "*/*" accepts any file type. The
                 receive_sharing_intent plugin reads the EXTRA_STREAM URI(s)
                 and hands them to Dart, which uploads via TagnetApp.uploadFile. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="*/*"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="*/*"/>
            </intent-filter>
        </activity>
        <!-- tagnet: foreground service hosting the native runtime. Not
             exported; the type must match FOREGROUND_SERVICE_DATA_SYNC. -->
        <service
            android:name=".TagnetService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
