# Rust
target/
**/*.rs.bk

# cargo-mobile
.cargo/
/gen

# macOS
.DS_Store

# Nix
.direnv/

# Flutter / Dart build outputs
app/build/
app/.dart_tool/
app/linux/flutter/ephemeral/

# Compiled native libraries (built from Rust, regenerated on build)
**/jniLibs/**/*.so

# Generated Dart entrypoint + bindings (regenerated by the flake, NOT source).
#
# app/lib/main.dart is copied per-platform from tagnet-bridge/app-template/
# (main.dart for Android, main_linux.dart for Linux) by the create-*/run-*
# commands, so it flips based on the last target built. app/lib/rust/ is the
# flutter_rust_bridge codegen output (dart_output in flutter_rust_bridge.yaml).
# Both are build artifacts: edit the templates / Rust API, never these. The
# real, tracked entrypoints live in tagnet-bridge/app-template/.
app/lib/

# Android / Gradle build outputs
app/android/build/
app/android/.gradle/
