# Rust
target/
**/*.rs.bk

# cargo-mobile
.cargo/
/gen

# macOS
.DS_Store

# Nix
.direnv/

# Flutter / Dart build outputs
app/build/
app/.dart_tool/
app/linux/flutter/ephemeral/

# Compiled native libraries (built from Rust, regenerated on build)
**/jniLibs/**/*.so

# flutter_rust_bridge codegen output (NOT source; regenerated by
# `nix run .#codegen`). Both halves are build artifacts, so neither is tracked:
#   - app/lib/rust/               (dart_output in flutter_rust_bridge.yaml)
#   - tagnet-bridge/src/frb_generated.rs  (rust_output there)
# app/lib/ otherwise holds the app's real, tracked Dart sources. Edit the Rust
# API (tagnet-bridge/src/api.rs), never these generated files.
app/lib/rust/
tagnet-bridge/src/frb_generated.rs

# Android / Gradle build outputs
app/android/build/
app/android/.gradle/
